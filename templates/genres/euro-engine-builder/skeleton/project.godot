; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Scaffolded from the NoxDev genre-template registry (id: euro-engine-builder).

config_version=5

[application]

config/name="Euro Engine-Builder Template"
run/main_scene="res://scenes/board.tscn"
config/features=PackedStringArray("4.6")

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[autoload]

GameManager="*res://scripts/game_manager.gd"

[euro_llm]

; OPTIONAL local-LLM-assisted AI seat (AI_LLM ControllerKind). Default DISABLED —
; the game touches no network unless you set enabled=true AND assign a seat the
; AI_LLM kind (e.g. GameManager.new_game_with_llm / the "You + LLM AI" button).
; With a provider unreachable, an AI_LLM seat falls back to the heuristic AI, so
; the game always progresses. Ollama convention: POST {host}{endpoint_path}.
enabled=false
host="http://localhost:11434"
endpoint_path="/api/generate"
model="llama3.2"
timeout_seconds=8.0

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194305,"key_label":0,"unicode":0,"echo":false,"script":null)]
}
restart={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194309,"key_label":0,"unicode":0,"echo":false,"script":null)]
}
