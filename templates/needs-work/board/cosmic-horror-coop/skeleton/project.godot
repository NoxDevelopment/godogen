; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Scaffolded from the NoxDev genre-template registry (id: cosmic-horror-coop).

config_version=5

[application]

config/name="Cosmic-Horror Co-op Template"
run/main_scene="res://addons/nox_ui/scenes/main_menu.tscn"
config/features=PackedStringArray("4.7")

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[autoload]
NoxSettings="*res://addons/nox_ui/game_settings.gd"
NoxShell="*res://addons/nox_ui/nox_shell.gd"

GameManager="*res://scripts/game_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=800
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194305,"key_label":0,"unicode":0,"echo":false,"script":null)]
}
restart={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194309,"key_label":0,"unicode":0,"echo":false,"script":null)]
}
