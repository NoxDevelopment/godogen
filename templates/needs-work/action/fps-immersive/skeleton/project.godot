; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Scaffolded from the NoxDev genre-template registry (id: fps-immersive).

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="FPS Immersive Template"
run/main_scene="res://scenes/test_room.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[autoload]

Audio="*res://addons/quick_audio/Audio.gd"
InputHelper="*res://addons/input_helper/input_helper.gd"
CogitoSceneManager="*res://COGITO/SceneManagement/cogito_scene_manager.gd"
CogitoQuestManager="*res://COGITO/QuestSystemPD/CogitoQuestManager.gd"
MenuTemplateManager="*res://COGITO/EasyMenus/Nodes/menu_template_manager.tscn"
GameManager="*res://scripts/game_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://COGITO/Theme/Cogito_Theme_A.tres"
theme/default_theme_scale=2.0

[importer_defaults]

wav={
"edit/loop_mode": 1
}

