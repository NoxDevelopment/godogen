; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[application]

config/name="FF Gamebook Template"
run/main_scene="res://addons/nox_ui/scenes/main_menu.tscn"
config/features=PackedStringArray("4.7")

[autoload]

NoxSettings="*res://addons/nox_ui/game_settings.gd"
NoxShell="*res://addons/nox_ui/nox_shell.gd"
FFSettings="*res://scripts/ff_settings.gd"
GameManager="*res://scripts/game_manager.gd"
AssetBinder="*res://scripts/asset_binder.gd"
AudioDirector="*res://scripts/audio_director.gd"
Adventure="*res://scripts/adventure.gd"
SaveManager="*res://scripts/save_manager.gd"
SceneLoader="*res://addons/loading/scene_loader.gd"
ContinueService="*res://addons/loading/continue_service.gd"
Net="*res://addons/nox_netcode/net_session.gd"
NetBridge="*res://addons/nox_netcode/session_bridge.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194305,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"button_index":6,"pressure":0.0,"pressed":false,"script":null)
]
}

[nox_netcode]

profile="authority-turn"
transport="websocket"
arbitration="leader"
default_port=24567
max_peers=8
disconnect_policy="pause-and-wait"
