[gd_resource type="Theme" load_steps=10 format=3]

; NoxDev shell theme — re-skinned for ff-gamebook (The Grey Tithe) so the standard
; menu/options/credits shell reads as the SAME illuminated book as the reading view
; (STYLE_GUIDE "one book"; typography SKILL display+body pairing). Fonts are the reused
; OFL faces already shipped under the skeleton: Cinzel (engraved display) for buttons/
; labels, MedievalSharp (warm readable body) as the default. The neutral Kenney grey
; button + brown panel are tinted to the STYLE_GUIDE parchment palette; ink text carries
; a parchment outline so it stays legible pressed over the cover backdrop.

[ext_resource type="Texture2D" path="res://addons/nox_ui/theme/kenney/buttonLong_grey.png" id="btn"]
[ext_resource type="Texture2D" path="res://addons/nox_ui/theme/kenney/panel_brown.png" id="pnl"]
[ext_resource type="FontFile" path="res://assets/reused/fonts/Cinzel.ttf" id="font_display"]
[ext_resource type="FontFile" path="res://assets/reused/fonts/MedievalSharp.ttf" id="font_body"]

