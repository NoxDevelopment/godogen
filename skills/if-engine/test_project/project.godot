; Engine configuration file.
; Minimal Godot 4 project that carries the nox_if_engine addon and is the
; runnable headless proof for the if-engine skill (P0). No autoloads required —
; the engine is class_name-registered pure RefCounted. Run the probe with:
;   Godot --headless --path <this dir> res://addons/nox_if_engine/probe/if_probe.tscn

config_version=5

[application]

config/name="nox_if_engine — P0 test project"
config/features=PackedStringArray("4.6")
run/main_scene="res://addons/nox_if_engine/probe/if_probe.tscn"

[debug]

gdscript/warnings/untyped_declaration=0
